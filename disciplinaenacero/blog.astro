---
// src/pages/blog.astro
// Listado de todas las reseñas — ordenadas por fecha descendente
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ResenaCard from '../components/ResenaCard.astro';

const posts = (await getCollection('blog'))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const featured = posts.filter(p => p.data.featured).slice(0, 3);
const resto    = posts.filter(p => !p.data.featured);
---

<BaseLayout
  title="Biblioteca de Acero — Disciplina en Acero"
  description="Reseñas de libros de desarrollo personal, disciplina y estoicismo desde el prisma de la Disciplina en Acero. No motivación. Forja."
>

  <main class="max-w-5xl mx-auto px-6 py-16">

    <!-- Header de la sección -->
    <div class="mb-16">
      <p class="text-red-700 uppercase tracking-widest text-sm font-semibold mb-4">
        Biblioteca de Acero
      </p>
      <h1 class="text-5xl font-bold text-white mb-6">
        Libros que no te consuelan. Te forjan.
      </h1>
      <p class="text-xl text-gray-400 max-w-2xl">
        Reseñas desde la doctrina de Disciplina en Acero. Cada libro analizado
        bajo un único filtro: ¿te ayuda a dejar de mentirte o solo decora tu identidad rota?
      </p>
    </div>

    <!-- Destacados -->
    {featured.length > 0 && (
      <section class="mb-16">
        <h2 class="text-sm uppercase tracking-widest text-gray-500 mb-8 font-semibold">
          Lecturas prioritarias
        </h2>
        <div class="grid md:grid-cols-3 gap-6">
          {featured.map(post => <ResenaCard post={post} destacado={true} />)}
        </div>
      </section>
    )}

    <!-- Todas las reseñas -->
    <section>
      <h2 class="text-sm uppercase tracking-widest text-gray-500 mb-8 font-semibold">
        Todas las reseñas ({posts.length})
      </h2>
      <div class="grid md:grid-cols-2 gap-6">
        {posts.map(post => <ResenaCard post={post} />)}
      </div>
    </section>

  </main>

</BaseLayout>
