---
// src/layouts/BlogPostLayout.astro
// Layout principal de cada reseña — estética Disciplina en Acero
import { Image } from 'astro:assets';
import BaseLayout from './BaseLayout.astro';

const { frontmatter } = Astro.props;
const {
  title, description, date, readTime,
  image, amazon_link, tags, category
} = frontmatter;

const formattedDate = new Date(date).toLocaleDateString('es-ES', {
  year: 'numeric', month: 'long', day: 'numeric'
});
---

<BaseLayout title={title} description={description}>

  <article class="max-w-3xl mx-auto px-6 py-12 prose prose-invert prose-lg">

    <!-- Meta de la reseña -->
    <div class="flex items-center gap-4 text-sm text-gray-400 mb-8 not-prose">
      <span class="uppercase tracking-widest font-semibold text-red-700">
        {category || 'Reseña de Acero'}
      </span>
      <span>•</span>
      <time datetime={date}>{formattedDate}</time>
      {readTime && <span>• {readTime} min de forja</span>}
    </div>

    {image && (
      <Image
        src={image}
        alt={title}
        width={800}
        height={450}
        class="w-full rounded-xl mb-10 shadow-2xl not-prose"
        loading="eager"
      />
    )}

    <h1 class="text-4xl md:text-5xl font-bold tracking-tight text-white mb-6 not-prose">
      {title}
    </h1>

    <!-- Descripción destacada -->
    <div class="border-l-4 border-red-700 pl-6 mb-12 not-prose">
      <p class="text-xl text-gray-300 italic">{description}</p>
    </div>

    <!-- Contenido Markdown generado por forge_blog.py -->
    <slot />

    <!-- CTA principal hacia el libro de Andrés -->
    <div class="mt-16 p-8 bg-zinc-950 border border-red-900 rounded-2xl not-prose">
      <h2 class="text-2xl font-bold mb-4 text-white">
        El mapa no forja al hombre. El acero sí.
      </h2>
      <p class="text-lg text-gray-300 mb-6">
        Este libro te da el "qué". Sin identidad de acero, sin dejar de mentirte,
        seguirás siendo el mismo esclavo con mejores hábitos.
      </p>
      <a
        href="/el-hombre-que-dejo-de-mentirse"
        class="inline-block bg-red-700 hover:bg-red-600 text-white font-bold px-8 py-4 rounded-xl transition-all text-lg"
      >
        Forja tu identidad → Lee "El Hombre que Dejó de Mentirse"
      </a>

      {amazon_link && (
        <div class="mt-8 pt-8 border-t border-zinc-800">
          <p class="text-sm text-gray-400 mb-3">
            Apoya la forja comprando el libro reseñado:
          </p>
          <a
            href={amazon_link}
            target="_blank"
            rel="noopener noreferrer sponsored"
            class="text-amber-400 hover:text-amber-300 underline font-medium"
          >
            → Comprar en Amazon (enlace afiliado)
          </a>
        </div>
      )}
    </div>

    <!-- Tags -->
    {tags && tags.length > 0 && (
      <div class="mt-12 flex flex-wrap gap-2 not-prose">
        {tags.map((tag: string) => (
          <span class="text-xs uppercase tracking-widest bg-zinc-900 px-4 py-2 rounded-full text-gray-400">
            #{tag}
          </span>
        ))}
      </div>
    )}

  </article>

</BaseLayout>

<style>
  /* Estilos doctrinales — el contenido generado por el Alchemist hereda esto */
  .prose :global(h2) {
    color: #fff;
    border-bottom: 2px solid #7f1d1d;
    padding-bottom: 0.5rem;
  }
  .prose :global(h3) {
    color: #e5e7eb;
  }
  .prose :global(strong) {
    color: #ef4444;
  }
  .prose :global(blockquote) {
    border-left-color: #7f1d1d;
    color: #d1d5db;
  }
  .prose :global(a) {
    color: #fbbf24;
  }
  .prose :global(a:hover) {
    color: #f59e0b;
  }
</style>
