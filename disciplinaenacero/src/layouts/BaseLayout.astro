---
// BaseLayout estilo Disciplina en Acero
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const { title, description } = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <BaseHead title={title} description={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Barlow:ital,wght@0,300;0,400;0,600;0,700;1,300&family=Barlow+Condensed:wght@400;600;700&display=swap" rel="stylesheet">
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>

<style is:global>
  :root {
    --negro: #0A0A0A;
    --carbon: #111111;
    --forja: #1A1A1A;
    --acero: #2A2A2A;
    --gris-medio: #555555;
    --gris-claro: #999999;
    --blanco: #F0EDE8;
    --crema: #E8E3DA;
    --dorado: #C8A96E;
    --dorado-vivo: #D4B483;
    --rojo-forja: #8B1A1A;
    --rojo-brasa: #A52020;
  }

  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    background-color: var(--negro);
    color: var(--blanco);
    font-family: 'Barlow', sans-serif;
    font-weight: 300;
    line-height: 1.7;
    min-height: 100vh;
  }

  main {
    padding-top: 80px;
  }

  h1, h2, h3 {
    font-family: 'Bebas Neue', sans-serif;
    font-weight: 400;
    letter-spacing: 0.04em;
    line-height: 1.05;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  .etiqueta {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--dorado);
  }

  .separador {
    width: 40px;
    height: 2px;
    background: var(--dorado);
    margin: 1.5rem 0;
  }

  .dorado {
    color: var(--dorado);
  }
</style>
