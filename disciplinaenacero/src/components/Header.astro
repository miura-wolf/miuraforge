---
// Header estilo Disciplina en Acero — dark, dorado, Bebas Neue
import { SITE_TITLE } from '../consts';
---

<header class="nav" role="navigation">
  <a href="/" class="nav__logo">DISCIPLINA <span>EN ACERO</span></a>
  <ul class="nav__links">
    <li><a href="/#doctrina">Doctrina</a></li>
    <li><a href="/blog">Biblioteca</a></li>
    <li><a href="/about">Nosotros</a></li>
    <li><a href="/el-hombre-que-dejo-de-mentirse">El Libro</a></li>
  </ul>
  <a href="/#fundamento" class="nav__cta">Acceso Gratuito</a>
</header>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Barlow+Condensed:wght@400;600&display=swap');

  :root {
    --negro: #0A0A0A;
    --carbon: #111111;
    --acero: #2A2A2A;
    --gris-claro: #999999;
    --blanco: #F0EDE8;
    --dorado: #C8A96E;
    --dorado-vivo: #D4B483;
  }

  header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    padding: 1.2rem 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: linear-gradient(to bottom, rgba(10,10,10,0.98), transparent);
    font-family: 'Barlow Condensed', sans-serif;
  }

  header.scrolled {
    background: rgba(10,10,10,0.97);
    border-bottom: 1px solid var(--acero);
  }

  .nav__logo {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.4rem;
    letter-spacing: 0.08em;
    color: var(--blanco);
    text-decoration: none;
  }

  .nav__logo span {
    color: var(--dorado);
  }

  .nav__links {
    display: flex;
    gap: 2rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav__links a {
    font-size: 0.8rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--gris-claro);
    text-decoration: none;
    transition: color 0.2s;
  }

  .nav__links a:hover {
    color: var(--dorado);
  }

  .nav__cta {
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--dorado);
    border: 1px solid var(--dorado);
    padding: 0.6rem 1.2rem;
    text-decoration: none;
    transition: all 0.3s;
  }

  .nav__cta:hover {
    background: var(--dorado);
    color: var(--negro);
  }

  @media (max-width: 768px) {
    .nav__links {
      display: none;
    }
  }
</style>
