---
const today = new Date();
---

<footer class="footer">
  <div class="container">
    <div class="footer__grid">
      <div class="footer__marca">
        <a href="/" class="footer__logo">DISCIPLINA <span>EN ACERO</span></a>
        <p class="footer__slogan">No consuela. No valida. Diagnostica y ordena.</p>
      </div>
      
      <div class="footer__links">
        <a href="/#doctrina">Doctrina</a>
        <a href="/blog">Biblioteca</a>
        <a href="/about">Nosotros</a>
        <a href="/el-hombre-que-dejo-de-mentirse">El Libro</a>
      </div>
    </div>
    
    <div class="footer__separador"></div>
    
    <div class="footer__legal">
      <p>&copy; {today.getFullYear()} Disciplina en Acero. Todos los derechos reservados.</p>
      <a href="/terminos">Términos de uso</a>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--carbon);
    border-top: 1px solid var(--acero);
    padding: 4rem 0 2rem;
    margin-top: 4rem;
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .footer__grid {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 2rem;
    align-items: start;
    margin-bottom: 2rem;
  }

  .footer__logo {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.5rem;
    letter-spacing: 0.08em;
    color: var(--blanco);
    display: block;
    margin-bottom: 0.5rem;
  }

  .footer__logo span {
    color: var(--dorado);
  }

  .footer__slogan {
    font-size: 0.9rem;
    color: var(--gris-claro);
    font-style: italic;
  }

  .footer__links {
    display: flex;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .footer__links a {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 0.85rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--gris-claro);
    transition: color 0.2s;
  }

  .footer__links a:hover {
    color: var(--dorado);
  }

  .footer__separador {
    height: 1px;
    background: var(--acero);
    margin: 2rem 0;
  }

  .footer__legal {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .footer__legal p {
    font-size: 0.85rem;
    color: var(--gris-medio);
    margin: 0;
  }

  .footer__legal a {
    font-size: 0.85rem;
    color: var(--gris-medio);
    text-decoration: underline;
    text-decoration-color: var(--acero);
    transition: all 0.2s;
  }

  .footer__legal a:hover {
    color: var(--dorado);
    text-decoration-color: var(--dorado);
  }

  @media (max-width: 768px) {
    .footer__grid {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .footer__links {
      justify-content: center;
    }

    .footer__legal {
      flex-direction: column;
      text-align: center;
    }
  }
</style>
