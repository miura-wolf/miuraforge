---
// Confirmación — Acceso concedido + pregunta de motivación
import BaseLayout from '../layouts/BaseLayout.astro';

const GOOGLE_DRIVE_URL = 'https://drive.google.com/file/d/1uQzbifYe2FXWHOqHgUGoiB-gFGT0HQlG/view?usp=sharing';
---

<BaseLayout 
  title="Acceso Concedido — Disciplina en Acero"
  description="El Fundamento está en camino a tu correo. Gracias por confiar en el proceso."
>
  <style>
    .confirmacion {
      flex: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 8rem 2rem 4rem;
      position: relative;
      overflow: hidden;
      min-height: 80vh;
    }

    .confirmacion__bg {
      position: absolute;
      inset: 0;
      background:
        radial-gradient(ellipse at 50% 40%, rgba(200,169,110,0.06) 0%, transparent 60%),
        linear-gradient(180deg, var(--negro) 0%, var(--carbon) 100%);
    }

    .confirmacion__inner {
      position: relative;
      z-index: 1;
      max-width: 640px;
      width: 100%;
      text-align: center;
      margin: 0 auto;
    }

    .confirmacion__sello {
      width: 80px;
      height: 80px;
      border: 1px solid var(--dorado);
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 2rem;
      font-size: 2rem;
    }

    .confirmacion__titulo {
      margin-bottom: 0.5rem;
    }

    .confirmacion__sub {
      margin-bottom: 3rem;
      font-size: 1rem;
    }

    .confirmacion__divider {
      border: none;
      border-top: 1px solid var(--acero);
      margin: 3rem 0;
    }

    .motivo-bloque {
      background: var(--forja);
      border: 1px solid var(--acero);
      padding: 2.5rem;
      text-align: left;
    }

    .motivo-bloque__label {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 0.7rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--dorado);
      margin-bottom: 1rem;
      display: block;
    }

    .motivo-bloque h3 {
      font-size: 1.3rem;
      margin-bottom: 0.5rem;
    }

    .motivo-bloque p {
      font-size: 0.9rem;
      margin-bottom: 1.5rem;
    }

    .motivo-bloque textarea {
      width: 100%;
      background: var(--acero);
      border: 1px solid var(--gris-medio);
      color: var(--blanco);
      padding: 1rem 1.2rem;
      font-family: 'Barlow', sans-serif;
      font-size: 0.95rem;
      line-height: 1.6;
      resize: vertical;
      min-height: 100px;
      outline: none;
      transition: border-color 0.2s;
      margin-bottom: 1rem;
    }

    .motivo-bloque textarea:focus {
      border-color: var(--dorado);
    }

    .motivo-bloque textarea::placeholder {
      color: var(--gris-medio);
    }

    .motivo-bloque__aviso {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 0.7rem;
      letter-spacing: 0.08em;
      color: var(--gris-medio);
      margin-top: 0.75rem;
    }

    .motivo-enviado {
      display: none;
      text-align: center;
      padding: 2rem;
    }

    .motivo-enviado .etiqueta {
      margin-bottom: 1rem;
      display: block;
    }

    .motivo-enviado p {
      font-size: 0.95rem;
    }

    .siguiente-paso {
      margin-top: 3rem;
    }

    .siguiente-paso p {
      font-size: 0.85rem;
      margin-bottom: 1.5rem;
    }

    .btn {
      display: inline-block;
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      padding: 1rem 2rem;
      border: 1px solid var(--dorado);
      text-decoration: none;
      text-align: center;
      cursor: pointer;
      transition: all 0.3s;
    }

    .btn--primario {
      background: var(--dorado);
      color: var(--negro);
    }

    .btn--primario:hover {
      background: transparent;
      color: var(--dorado);
    }
  </style>

  <section class="confirmacion">
    <div class="confirmacion__bg"></div>
    <div class="confirmacion__inner">

      <div class="confirmacion__sello">⚔</div>

      <h1 class="confirmacion__titulo">
        Acceso <span class="dorado">Concedido.</span>
      </h1>
      <p class="confirmacion__sub">
        <span id="nombre-saludo"></span>El Fundamento está en camino a tu correo.
        Revisa tu bandeja — incluyendo spam.
      </p>

      <hr class="confirmacion__divider">

      <!-- Pregunta de motivación -->
      <div class="motivo-bloque" id="bloque-motivo">
        <span class="motivo-bloque__label">Una sola pregunta</span>
        <h3>¿Qué te trajo aquí?</h3>
        <p>No hay respuesta correcta. Solo una línea honesta de tu parte.</p>
        <textarea
          id="textarea-motivo"
          placeholder="Llevo tiempo sintiéndome paralizado / Vi un video que me golpeó / No sé bien, pero algo no cuadra..."
          maxlength="500"
        ></textarea>
        <button
          class="btn btn--primario"
          style="width: 100%;"
          onclick="enviarMotivo()"
          id="btn-motivo"
        >
          ENVIAR Y RECIBIR MI ACCESO
        </button>
        <p class="motivo-bloque__aviso">
          Tu respuesta es privada. No se publica. Nos ayuda a entender mejor a quién le hablamos.
        </p>
      </div>

      <!-- Estado tras envío -->
      <div class="motivo-enviado" id="motivo-enviado">
        <span class="etiqueta">Recibido</span>
        <p>Gracias. Eso es exactamente el tipo de honestidad que necesita este proyecto.</p>
      </div>

      <div class="siguiente-paso">
        <p>El Fundamento ya está disponible. Descárgalo ahora.</p>
        <a href={GOOGLE_DRIVE_URL} target="_blank" rel="noopener" class="btn btn--primario">⬇ DESCARGAR EL FUNDAMENTO</a>
      </div>

    </div>
  </section>

  <script is:inline>
    // Leer params de URL
    const params = new URLSearchParams(window.location.search);
    const nombre = params.get('nombre') || '';
    const email = params.get('email') || '';
    const APPS_SCRIPT_URL = params.get('url') || 'https://script.google.com/macros/s/AKfycbwgVox-b6T_P_79pjx0Q9zUGAqYk_p7a_uZFaz2alCdHU-ULc3gaRCs_OMBA2LfBzzm/exec';

    // Personalizar saludo con nombre
    if (nombre) {
      document.getElementById('nombre-saludo').textContent = nombre + ', ';
    }

    // Enviar motivación
    async function enviarMotivo() {
      const motivo = document.getElementById('textarea-motivo').value.trim();
      const btn = document.getElementById('btn-motivo');

      // Si no escribió nada, igual puede continuar
      if (!motivo) {
        ocultarFormMotivo();
        return;
      }

      btn.textContent = 'ENVIANDO...';
      btn.disabled = true;

      try {
        await fetch(APPS_SCRIPT_URL, {
          method: 'POST',
          headers: { 'Content-Type': 'text/plain' },
          body: JSON.stringify({ accion: 'motivo', email, motivacion: motivo })
        });
      } catch (err) {
        console.warn('[Leads] Error registrando motivación:', err);
      }

      ocultarFormMotivo();
    }

    function ocultarFormMotivo() {
      document.getElementById('bloque-motivo').style.display = 'none';
      document.getElementById('motivo-enviado').style.display = 'block';
    }
  </script>
</BaseLayout>
