---
// El Fundamento — Lead Magnet Page
import BaseLayout from '../layouts/BaseLayout.astro';

const GOOGLE_DRIVE_URL = 'https://drive.google.com/file/d/1uQzbifYe2FXWHOqHgUGoiB-gFGT0HQlG/view?usp=sharing';
---

<BaseLayout 
  title="El Fundamento — Disciplina en Acero"
  description="Protocolo 30 días. Disciplina en Acero. No es motivación. Es la arquitectura mínima que se instala primero."
>
  <style>
    .fundamento-hero {
      flex: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 8rem 2rem 4rem;
      position: relative;
      overflow: hidden;
      background: var(--negro);
      min-height: 100vh;
    }

    .fundamento-hero__bg {
      position: absolute;
      inset: 0;
      background:
        radial-gradient(ellipse at 50% 40%, rgba(200,169,110,0.07) 0%, transparent 60%),
        radial-gradient(ellipse at 80% 80%, rgba(139,26,26,0.05) 0%, transparent 50%);
    }

    .fundamento-hero__deco {
      position: absolute;
      right: -2rem;
      bottom: -4rem;
      font-family: 'Bebas Neue', sans-serif;
      font-size: 20vw;
      color: var(--acero);
      opacity: 0.07;
      line-height: 1;
      user-select: none;
      letter-spacing: -0.05em;
    }

    .fundamento-inner {
      position: relative;
      z-index: 1;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 6rem;
      align-items: center;
      max-width: 1100px;
      width: 100%;
      margin: 0 auto;
    }

    .fundamento-portada {
      display: flex;
      justify-content: center;
    }

    .fundamento-libro {
      width: 240px;
      aspect-ratio: 0.7;
      background: linear-gradient(145deg, #1A1A1A 0%, #0D0D0D 100%);
      border: 1px solid #333;
      padding: 2.5rem 2rem;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      position: relative;
      box-shadow:
        20px 20px 60px rgba(0,0,0,0.7),
        -3px 0 0 rgba(200,169,110,0.35),
        inset 2px 0 0 rgba(255,255,255,0.02);
      transform: perspective(800px) rotateY(-10deg) rotateX(2deg);
      transition: transform 0.4s;
    }

    .fundamento-libro:hover {
      transform: perspective(800px) rotateY(-4deg) rotateX(1deg);
    }

    .fundamento-libro__linea {
      height: 1px;
      background: var(--dorado);
      opacity: 0.4;
    }

    .fundamento-libro__editorial {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 0.55rem;
      letter-spacing: 0.3em;
      color: var(--dorado);
      text-transform: uppercase;
      margin-top: 0.75rem;
    }

    .fundamento-libro__titulo {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 2rem;
      line-height: 1.05;
      color: var(--blanco);
    }

    .fundamento-libro__sub {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 0.6rem;
      letter-spacing: 0.15em;
      color: var(--gris-claro);
      text-transform: uppercase;
      line-height: 1.6;
    }

    .fundamento-libro__dias {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 3rem;
      color: var(--dorado);
      line-height: 1;
      text-align: center;
      opacity: 0.5;
    }

    .fundamento-libro__autor {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 0.65rem;
      letter-spacing: 0.2em;
      color: var(--dorado);
      text-transform: uppercase;
    }

    .fundamento-contenido .separador {
      margin: 1.5rem 0;
    }

    .fundamento-contenido p {
      margin-bottom: 1.25rem;
    }

    .fundamento-lista {
      list-style: none;
      margin: 1.5rem 0 2.5rem;
    }

    .fundamento-lista li {
      display: flex;
      align-items: flex-start;
      gap: 1rem;
      padding: 0.75rem 0;
      border-bottom: 1px solid var(--acero);
      font-size: 0.95rem;
      color: var(--gris-claro);
    }

    .fundamento-lista li::before {
      content: '⚔';
      color: var(--dorado);
      font-size: 0.75rem;
      margin-top: 0.15rem;
      flex-shrink: 0;
    }

    .fundamento-cta {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .fundamento-aviso {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 0.7rem;
      letter-spacing: 0.1em;
      color: var(--gris-medio);
    }

    .gmail-tip {
      background: var(--forja);
      border: 1px solid var(--acero);
      border-left: 2px solid var(--dorado);
      padding: 1rem 1.5rem;
      margin-top: 1.5rem;
    }

    .gmail-tip p {
      font-size: 0.82rem;
      color: var(--gris-claro);
      margin: 0;
      line-height: 1.6;
    }

    .gmail-tip strong {
      color: var(--dorado);
    }

    .fundamento-input {
      background: var(--acero);
      border: 1px solid var(--gris-medio);
      color: var(--blanco);
      padding: 1rem 1.2rem;
      font-family: 'Barlow', sans-serif;
      font-size: 0.95rem;
      outline: none;
      transition: border-color 0.2s;
      width: 100%;
    }

    .fundamento-input:focus {
      border-color: var(--dorado);
    }

    .fundamento-input::placeholder {
      color: var(--gris-medio);
    }

    .que-sigue {
      padding: 6rem 0;
      background: var(--carbon);
      border-top: 1px solid var(--acero);
    }

    .que-sigue__grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1px;
      background: var(--acero);
      margin-top: 3rem;
    }

    .que-sigue__item {
      background: var(--carbon);
      padding: 2.5rem;
      transition: background 0.3s;
    }

    .que-sigue__item:hover {
      background: var(--negro);
    }

    .que-sigue__num {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 3rem;
      color: var(--acero);
      line-height: 1;
      margin-bottom: 1rem;
      transition: color 0.3s;
    }

    .que-sigue__item:hover .que-sigue__num {
      color: var(--dorado);
    }

    .que-sigue__item h3 {
      font-size: 1.2rem;
      margin-bottom: 0.5rem;
    }

    .libro-teaser {
      padding: 6rem 0;
      background: var(--negro);
    }

    .libro-teaser__inner {
      display: grid;
      grid-template-columns: 1.4fr 1fr;
      gap: 5rem;
      align-items: center;
      max-width: 1100px;
      margin: 0 auto;
      padding: 0 2rem;
    }

    .libro-teaser__badge {
      display: inline-block;
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 0.65rem;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      padding: 0.35rem 0.9rem;
      border: 1px solid var(--rojo-brasa);
      color: var(--rojo-brasa);
      margin-bottom: 1.5rem;
    }

    .libro-teaser__precio {
      display: flex;
      align-items: baseline;
      gap: 0.5rem;
      margin: 2rem 0;
    }

    .libro-teaser__precio-num {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 4rem;
      color: var(--blanco);
      line-height: 1;
    }

    .libro-teaser__precio-moneda {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 1.2rem;
      color: var(--gris-claro);
    }

    .libro-teaser__precio-desc {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 0.7rem;
      letter-spacing: 0.1em;
      color: var(--gris-medio);
      margin-top: 0.25rem;
    }

    .libro-teaser__mock {
      width: 200px;
      aspect-ratio: 0.68;
      background: linear-gradient(145deg, #1A1A1A, #0D0D0D);
      border: 1px solid #333;
      padding: 2rem 1.5rem;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      box-shadow: 15px 15px 40px rgba(0,0,0,0.7), -2px 0 0 rgba(200,169,110,0.3);
      transform: perspective(800px) rotateY(-8deg);
      margin-left: auto;
    }

    .btn {
      display: inline-block;
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      padding: 1rem 2rem;
      border: 1px solid var(--dorado);
      text-decoration: none;
      text-align: center;
      cursor: pointer;
      transition: all 0.3s;
    }

    .btn--primario {
      background: var(--dorado);
      color: var(--negro);
    }

    .btn--primario:hover {
      background: transparent;
      color: var(--dorado);
    }

    @media (max-width: 900px) {
      .fundamento-inner {
        grid-template-columns: 1fr;
        gap: 3rem;
      }

      .fundamento-portada {
        display: none;
      }

      .que-sigue__grid {
        grid-template-columns: 1fr;
      }

      .libro-teaser__inner {
        grid-template-columns: 1fr;
      }

      .libro-teaser__mock {
        display: none;
      }

      .fundamento-hero__deco {
        display: none;
      }
    }
  </style>

  <section class="fundamento-hero">
    <div class="fundamento-hero__bg"></div>
    <div class="fundamento-hero__deco" aria-hidden="true">30</div>

    <div class="fundamento-inner">
      <div class="fundamento-portada">
        <div class="fundamento-libro">
          <div>
            <div class="fundamento-libro__linea"></div>
            <div class="fundamento-libro__editorial" style="margin-top:0.75rem;">Disciplina en Acero</div>
          </div>
          <div>
            <div class="fundamento-libro__titulo">El<br>Funda<br>mento</div>
            <div class="fundamento-libro__dias">30</div>
            <div class="fundamento-libro__sub">Días de protocolo<br>Sin motivación vacía</div>
          </div>
          <div>
            <div class="fundamento-libro__autor">Andrés Sánchez</div>
            <div style="height:8px;"></div>
            <div class="fundamento-libro__linea"></div>
          </div>
        </div>
      </div>

      <div class="fundamento-contenido">
        <span class="etiqueta">Acceso Gratuito</span>
        <div class="separador"></div>
        <h1 style="font-size: clamp(2.5rem, 5vw, 4rem);">
          El Fundamento.<br><span class="dorado">Tu protocolo.</span>
        </h1>
        <p>
          No es motivación. Es la arquitectura mínima que se instala primero.
          Lo que la consistencia produce que la intensidad nunca pudo.
        </p>

        <ul class="fundamento-lista">
          <li>30 días de protocolo estructurado sin motivación vacía</li>
          <li>Los 4 dolores que mantienen al hombre paralizado</li>
          <li>La distinción entre identidad real y máscara construida</li>
          <li>La tabla de las tres columnas — donde empieza la diferencia</li>
          <li>Acciones físicas concretas, no reflexiones abstractas</li>
        </ul>

        <div class="fundamento-cta">
          <form id="form-fundamento" class="fundamento-form" style="display: flex; flex-direction: column; gap: 1rem;">
            <input 
              type="email" 
              id="email-fundamento"
              placeholder="tu@correo.com"
              required
              class="fundamento-input"
              style="background: var(--acero); border: 1px solid var(--gris-medio); color: var(--blanco); padding: 1rem 1.2rem; font-size: 0.95rem; outline: none; transition: border-color 0.2s;"
            />
            <button
              type="submit"
              class="btn btn--primario"
              id="btn-descarga"
            >
              ⬇ DESCARGAR EL FUNDAMENTO — GRATIS
            </button>
          </form>
          <p class="fundamento-aviso">PDF · Acceso inmediato · Te enviamos el link por correo</p>
        </div>

        <div class="gmail-tip">
          <p>
            <strong>¿El correo llegó a Promociones?</strong>
            Muévelo a tu bandeja principal — los próximos llegarán directo.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="que-sigue">
    <div class="container">
      <div style="text-align:center; margin-bottom:1rem;">
        <span class="etiqueta reveal">El protocolo en 3 movimientos</span>
        <div class="separador separador--centro reveal"></div>
        <h2 class="reveal">Cómo usar<br><span class="dorado">El Fundamento.</span></h2>
      </div>
      <div class="que-sigue__grid">
        <div class="que-sigue__item reveal">
          <div class="que-sigue__num">01</div>
          <h3>Lee el diagnóstico</h3>
          <p>Los primeros dos capítulos nombran con precisión lo que llevas tiempo experimentando sin palabras exactas.</p>
        </div>
        <div class="que-sigue__item reveal">
          <div class="que-sigue__num">02</div>
          <h3>Llena la tabla</h3>
          <p>El Capítulo V tiene una tabla de tres columnas. No la saltes. Ahí empieza el trabajo real — y donde la mayoría abandona.</p>
        </div>
        <div class="que-sigue__item reveal">
          <div class="que-sigue__num">03</div>
          <h3>30 días. Sin excepciones.</h3>
          <p>El protocolo no mide intensidad. Mide consistencia. Una acción mínima diaria ejecutada sin negociación.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="libro-teaser">
    <div class="libro-teaser__inner">
      <div class="reveal">
        <div class="libro-teaser__badge">Diagnóstico completo</div>
        <h2>
          El Fundamento es el suelo.<br>
          <span class="dorado">El diagnóstico completo<br>es la arquitectura.</span>
        </h2>
        <p style="margin-top:1.5rem;">
          El Fundamento te da el protocolo de base. Pero hay cuatro mecanismos exactos que mantienen al hombre paralizado — y ningún protocolo de 30 días los nombra todos.
        </p>
        <p>
          <em style="color:var(--blanco); font-style:normal;">El Hombre que Dejó de Mentirse</em> es el diagnóstico quirúrgico completo. 101 páginas. Cinco capítulos. Una sola dirección.
        </p>
        <div class="libro-teaser__precio">
          <span class="libro-teaser__precio-moneda">$</span>
          <span class="libro-teaser__precio-num">9</span>
          <span class="libro-teaser__precio-moneda">USD</span>
        </div>
        <p class="libro-teaser__precio-desc">Precio de lanzamiento — sube a $17 después de la primera semana</p>
        <div style="margin-top:2rem;">
          <a href="/el-hombre-que-dejo-de-mentirse" class="btn btn--primario">VER EL DIAGNÓSTICO COMPLETO →</a>
        </div>
      </div>
      <div class="reveal" style="display:flex; justify-content:center;">
        <div class="libro-teaser__mock">
          <div style="height:1px; background:var(--dorado); opacity:0.4;"></div>
          <div>
            <div style="font-family:'Bebas Neue',sans-serif; font-size:1.6rem; line-height:1.05; color:var(--blanco);">El Hombre que Dejó de Mentirse</div>
          </div>
          <div>
            <div style="font-family:var(--fuente-etiq); font-size:0.6rem; letter-spacing:0.2em; color:var(--dorado);">ANDRÉS SÁNCHEZ</div>
            <div style="height:1px; background:var(--dorado); opacity:0.4; margin-top:0.75rem;"></div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script is:inline>
  const APPS_SCRIPT_URL = 'https://script.google.com/macros/s/AKfycbwgVox-b6T_P_79pjx0Q9zUGAqYk_p7a_uZFaz2alCdHU-ULc3gaRCs_OMBA2LfBzzm/exec';
  const GOOGLE_DRIVE_URL = 'https://drive.google.com/file/d/1uQzbifYe2FXWHOqHgUGoiB-gFGT0HQlG/view?usp=sharing';

  // Captura de lead antes de descarga
  const form = document.getElementById('form-fundamento');
  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const email = document.getElementById('email-fundamento').value.trim();
      const btn = document.getElementById('btn-descarga');
      
      if (!email || !email.includes('@')) return;
      
      btn.textContent = 'PROCESANDO...';
      btn.disabled = true;
      
      // Guardar en Sheets
      try {
        await fetch(APPS_SCRIPT_URL, {
          method: 'POST',
          headers: { 'Content-Type': 'text/plain' },
          body: JSON.stringify({ 
            accion: 'capturar', 
            nombre: '', 
            email, 
            fuente: 'fundamento_directo' 
          })
        });
      } catch (err) {
        console.warn('[Leads] Error:', err);
      }
      
      // Abrir PDF en nueva pestaña
      window.open(GOOGLE_DRIVE_URL, '_blank');
      
      // Cambiar texto del botón
      btn.textContent = '✓ PDF ABIERTO — REVISA TU CORREO';
      btn.style.background = 'var(--forja)';
      btn.style.color = 'var(--dorado)';
      btn.style.border = '1px solid var(--dorado)';
    });
  }
  
  // Personalizar si viene con nombre
  const params = new URLSearchParams(window.location.search);
  const nombre = params.get('nombre');
  if (nombre && form) {
    const input = document.getElementById('email-fundamento');
    input.placeholder = `${nombre.toUpperCase()}, tu@correo.com`;
  }
</script>
